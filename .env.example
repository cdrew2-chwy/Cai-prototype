# Optional: if the dev client cannot reach the API, set this (default is http://127.0.0.1:3001).
# VITE_API_ORIGIN=http://127.0.0.1:3001

# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: API port (Vite proxies /api here). Default 3001.
# PORT=3001
