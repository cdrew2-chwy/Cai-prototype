# Optional: if the dev client cannot reach the API, set this (default is http://127.0.0.1:3001).
# VITE_API_ORIGIN=http://127.0.0.1:3001

# Optional: Vite `server.open` uses the system browser (not Cursor’s integrated browser).
# In Cursor/VS Code’s integrated terminal it is skipped by default; use Run → “Cai: dev + integrated browser” (F5) or ⌘-click the localhost link in the terminal.
# CAI_DEV_OPEN=1  — always open system browser when Vite is ready
# CAI_DEV_OPEN=0  — never open system browser

# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: cap completion length (often faster / cheaper). Omit both for no cap.
# OPENAI_MAX_TOKENS_WELCOME=512
# OPENAI_MAX_TOKENS_CHAT=2048

# Optional: API port in dev (Vite proxies /api here). Default 3001.
# In production (`npm run build` then `npm start`), PORT is the public HTTP port for UI + API together.
# PORT=3001
# Optional: bind address for production (default 0.0.0.0 so Railway/Render can route traffic).
# HOST=0.0.0.0

# Chewy PDP enrichment (order cards with product image + title from a PDP URL) fetches
# https://www.chewy.com/… in Node. Chewy often returns HTTP 429 for script-like traffic.
# Product images in the UI load via GET /api/chewy-product-image (server-side fetch) so the browser
# is not blocked by Chewy CDN hotlink rules; the same cookie is reused for that upstream fetch.
# Paste a **Cookie** header from your browser (DevTools → Network → a chewy.com request)
# to unblock scraping in local dev. Example: _cfuvid=…; _ga=… (values change; do not commit real cookies).
# CHEWY_PDP_COOKIE=
# (alias) CHEWY_SESSION_COOKIE=
# Milliseconds to wait between PDP fetches when multiple orders have Chewy URLs (default 600). Set 0 to go as fast as possible locally (may increase HTTP 429 from Chewy).
# CHEWY_PDP_STAGGER_MS=600

# Product catalog CSV (PRODUCT_ID, PRODUCT_NAME, PRODUCT_PRICE, …) for list price + name merge.
# Default: data/product-catalog.csv (copy from your active catalog export).
# CHEWY_PRODUCT_CATALOG_PATH=

# Figma Code Connect: personal access token with Code Connect (Write) + File content (Read).
# Used by `npm run figma:connect:publish`. See https://help.figma.com/hc/en-us/articles/8085703771159-Manage-personal-access-tokens
# FIGMA_ACCESS_TOKEN=
